{
	"name": "to-openapi",
	"version": "0.1.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./plugins/bearer-auth": {
			"types": "./dist/plugins/bearer-auth.d.ts",
			"import": "./dist/plugins/bearer-auth.mjs",
			"require": "./dist/plugins/bearer-auth.cjs"
		},
		"./plugins/auto-tags": {
			"types": "./dist/plugins/auto-tags.d.ts",
			"import": "./dist/plugins/auto-tags.mjs",
			"require": "./dist/plugins/auto-tags.cjs"
		},
		"./plugins/error-responses": {
			"types": "./dist/plugins/error-responses.d.ts",
			"import": "./dist/plugins/error-responses.mjs",
			"require": "./dist/plugins/error-responses.cjs"
		},
		"./plugins/api-key-auth": {
			"types": "./dist/plugins/api-key-auth.d.ts",
			"import": "./dist/plugins/api-key-auth.mjs",
			"require": "./dist/plugins/api-key-auth.cjs"
		}
	},
	"files": [
		"dist",
		"docs/**/*.md",
		"skills",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsup",
		"check": "biome check .",
		"format": "biome check --write .",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs"
	},
	"peerDependencies": {
		"@standard-schema/spec": ">=1.1.0"
	},
	"peerDependenciesMeta": {
		"@standard-schema/spec": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"@seriousme/openapi-schema-validator": "^2.8.0",
		"@standard-schema/spec": "^1.1.0",
		"@valibot/to-json-schema": "^1.5.0",
		"arktype": "^2.1.29",
		"tsup": "^8.0.0",
		"typescript": "^5.7.0",
		"valibot": "^1.2.0",
		"vitepress": "^1.6.4",
		"vitest": "^3.0.0",
		"zod": "^4.3.6"
	}
}
